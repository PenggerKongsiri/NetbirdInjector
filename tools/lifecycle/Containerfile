FROM node:24.18.0-bookworm-slim

COPY . /workspace
COPY tools/lifecycle/systemctl /usr/local/bin/systemctl
RUN chmod 0755 /workspace/setup /workspace/install.sh /workspace/bootstrap-ubuntu.sh /workspace/packaging/*.sh /workspace/tools/lifecycle/*.sh /usr/local/bin/systemctl \
    && mkdir -p /run/systemd/system

CMD ["bash", "/workspace/tools/lifecycle/run.sh"]
