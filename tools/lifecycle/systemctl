#!/usr/bin/env bash
set -Eeuo pipefail

PID_FILE="/run/netbird-injector-manager.mock.pid"
LOG_FILE="/var/log/netbird-injector-manager.mock.log"

running() { [[ -f "${PID_FILE}" ]] && kill -0 "$(<"${PID_FILE}")" 2>/dev/null; }
start_service() {
  running && return
  NIM_CONFIG=/etc/netbird-injector-manager/config.json nohup /usr/bin/node --jitless --disable-proto=throw \
    /opt/netbird-injector-manager/current/src/main.mjs >> "${LOG_FILE}" 2>&1 &
  printf '%s\n' "$!" > "${PID_FILE}"
}
stop_service() {
  running || { rm -f -- "${PID_FILE}"; return; }
  local pid
  pid="$(<"${PID_FILE}")"
  kill -TERM "${pid}" 2>/dev/null || true
  for _ in {1..200}; do
    kill -0 "${pid}" 2>/dev/null || break
    sleep 0.1
  done
  if kill -0 "${pid}" 2>/dev/null; then kill -KILL "${pid}" 2>/dev/null || true; fi
  rm -f -- "${PID_FILE}"
}

command="${1:-}"; shift || true
case "${command}" in
  daemon-reload) ;;
  enable) [[ " $* " == *' --now '* ]] && start_service;;
  disable) [[ " $* " == *' --now '* ]] && stop_service;;
  start) start_service;;
  stop) stop_service;;
  restart) stop_service; start_service;;
  status) running && { printf 'active (mocked systemctl)\n'; exit 0; }; printf 'inactive (mocked systemctl)\n'; exit 3;;
  show) printf 'ActiveState=%s\n' "$(running && printf active || printf inactive)";;
  *) printf 'unsupported mocked systemctl command: %s\n' "${command}" >&2; exit 2;;
esac
